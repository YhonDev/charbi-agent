#!/bin/bash
CHARBI_HOME="$HOME/.charbi-agent"
export CHARBI_HOME
CHARBI_CLI="$CHARBI_HOME/cli"
CHARBI_VENV="$CHARBI_CLI/venv"
CHARBI_PYTHON="$CHARBI_VENV/bin/python3"
PID_FILE="$CHARBI_HOME/run/kernel.pid"
LOG_FILE="$CHARBI_HOME/run/kernel.log"
export PYTHONPATH="$CHARBI_CLI/src"

mkdir -p "$CHARBI_HOME/run"

is_kernel_running() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if [ -n "$PID" ] && ps -p "$PID" > /dev/null; then
            return 0
        fi
    fi
    return 1
}

stop_kernel() {
    if is_kernel_running; then
        PID=$(cat "$PID_FILE")
        echo "Deteniendo Charbi Kernel (PID: $PID)..."
        kill "$PID" 2>/dev/null
        sleep 2
        if ps -p "$PID" > /dev/null; then
            echo "Forzando cierre de $PID (SIGKILL)..."
            kill -9 "$PID" 2>/dev/null
        fi
        rm -f "$PID_FILE"
        echo "Charbi detenido."
    else
        echo "El kernel no parece estar activo. Limpiando procesos huérfanos..."
        ORPHANS=$(pgrep -f "kernel/bootstrap.ts")
        if [ -n "$ORPHANS" ]; then
            echo "Matando procesos detectados: $ORPHANS"
            kill -9 $ORPHANS 2>/dev/null
        fi
        rm -f "$PID_FILE"
    fi
}

start_kernel() {
    if is_kernel_running; then
        echo "Charbi Kernel YA ESTÁ CORRIENDO (PID: $(cat "$PID_FILE"))."
        return 0
    fi
    
    stop_kernel > /dev/null 2>&1
    
    echo "Iniciando Charbi Kernel..."
    cd "$CHARBI_HOME" || exit
    # Ejecutar con nohup y redirigir todo al log
    nohup npx ts-node kernel/bootstrap.ts > "$LOG_FILE" 2>&1 &
    NEW_PID=$!
    echo $NEW_PID > "$PID_FILE"
    echo "Kernel iniciado (PID: $NEW_PID). Ver logs con: tail -f $LOG_FILE"
}

case "$1" in
    start)
        start_kernel
        ;;
    stop)
        stop_kernel
        ;;
    restart)
        stop_kernel
        sleep 1
        start_kernel
        ;;
    status)
        if is_kernel_running; then
            echo "Charbi Kernel: ACTIVO (PID: $(cat "$PID_FILE"))"
            # Intentar llamar al status de python si existe para más detalle
            if [ -f "$CHARBI_CLI/src/charbi/commands/status.py" ]; then
                shift; $CHARBI_PYTHON -m charbi.commands.status "$@"
            fi
        else
            echo "Charbi Kernel: INACTIVO"
        fi
        ;;
    chat)
        shift; $CHARBI_PYTHON -m charbi.commands.chat "$@" ;;
    config)
        shift; $CHARBI_PYTHON -m charbi.commands.config "$@" ;;
    auth)
        shift; $CHARBI_PYTHON -m charbi.commands.auth "$@" ;;
    channels)
        shift; $CHARBI_PYTHON -m charbi.commands.channels "$@" ;;
    skill)
        shift; $CHARBI_PYTHON -m charbi.commands.skill "$@" ;;
    help|-h|--help)
        echo "Charbi CLI v2.5 - Comandos:"
        echo "  start, stop, restart, status"
        echo "  chat, config, auth, channels, skill"
        ;;
    *)
        if [ -n "$1" ]; then
            echo "Comando desconocido: $1"
        fi
        echo "Uso: charbi {start|stop|restart|status|chat|config|auth|channels|skill}"
        ;;
esac
